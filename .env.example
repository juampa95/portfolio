# Puerto (Cloud Run lo setea automáticamente en 8080)
PORT=8080

# --- Chatbot (Gemini) ---
# Sacá tu key gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Métricas de GitHub ---
# El runtime NO usa la API de GitHub: lee métricas pre-generadas desde Firestore.
# Sin Firestore, el dashboard usa un fixture de ejemplo (server/sample-metrics.js).
# La generación corre en la GitHub Action -> ver docs/metrics-pipeline.md

# --- Firestore (visitas + guestbook + métricas) ---
# En Cloud Run se activa solo (detecta K_SERVICE).
# Para probar Firestore en LOCAL, descomentá y configurá credenciales (ADC):
# FIRESTORE_ENABLED=true
# GOOGLE_CLOUD_PROJECT=tu-proyecto
